---
import { Icon } from "astro-icon/components";
import { Code } from "astro:components";

interface Props {
  code: string;
  lang?: string;
}

const { code, lang } = Astro.props;

// Languages Shiki recognizes. Anything else (our decorative "wildcard" /
// "domain" / "tcp" badges) falls back to shell highlighting while still
// showing the original label in the header.
const SHIKI_LANGS = new Set([
  "sh",
  "bash",
  "shell",
  "zsh",
  "http",
  "json",
  "toml",
  "yaml",
  "rust",
  "ts",
  "tsx",
  "js",
  "jsx",
]);
const shikiLang = (lang && SHIKI_LANGS.has(lang) ? lang : "sh") as any;
---

<div class="code-shell group">
  <div class="code-shell__header">
    <span class="code-shell__lang">{lang ?? ""}</span>
    <button
      type="button"
      class="copy-btn inline-flex h-7 w-7 items-center justify-center rounded-md text-muted opacity-0 transition group-hover:opacity-100 hover:text-[color:var(--color-accent-600)] dark:hover:text-[color:var(--color-accent-400)]"
      data-code={code}
      aria-label="Copy"
    >
      <Icon name="lucide:copy" class="h-3.5 w-3.5 copy-icon" />
      <Icon name="lucide:check" class="h-3.5 w-3.5 check-icon hidden" />
    </button>
  </div>
  <div class="code-shell__body">
    <Code
      code={code}
      lang={shikiLang}
      themes={{ light: "github-light", dark: "github-dark" }}
    />
  </div>
</div>

<script is:inline>
  document.querySelectorAll(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const code = btn.getAttribute("data-code") || "";
      try {
        await navigator.clipboard.writeText(code);
        btn.querySelector(".copy-icon")?.classList.add("hidden");
        btn.querySelector(".check-icon")?.classList.remove("hidden");
        setTimeout(() => {
          btn.querySelector(".copy-icon")?.classList.remove("hidden");
          btn.querySelector(".check-icon")?.classList.add("hidden");
        }, 1500);
      } catch (_) {}
    });
  });
</script>
