---
import Layout from "../layouts/Layout.astro";
import CodeBlock from "../components/CodeBlock.astro";
import { Icon } from "astro-icon/components";

const toc = [
  { id: "install", label: "Install" },
  { id: "install-homebrew", label: "Homebrew", depth: 1 },
  { id: "install-cargo", label: "Cargo", depth: 1 },
  { id: "install-script", label: "Install script", depth: 1 },
  { id: "authenticate", label: "Authenticate" },
  { id: "start-tunnel", label: "Start a tunnel" },
  { id: "http", label: "HTTP", depth: 1 },
  { id: "reserved", label: "Reserved hostname", depth: 1 },
  { id: "custom-domain", label: "Custom domain", depth: 1 },
  { id: "tcp", label: "Raw TCP", depth: 1 },
  { id: "next", label: "What's next" },
];

const installMethods = [
  { id: "homebrew", icon: "lucide:beer", label: "Homebrew", tagline: "macOS · Apple Silicon" },
  { id: "cargo", icon: "lucide:package", label: "Cargo", tagline: "Any Rust toolchain" },
  { id: "script", icon: "lucide:terminal", label: "Script", tagline: "One-line curl" },
];
---

<Layout title="Docs — Relay" description="Install relay via Homebrew or Cargo, add your auth token, and start tunneling.">
  <section class="container-page py-14 sm:py-20">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_240px]">
      <article class="prose-doc min-w-0">
        <div class="mb-8">
          <p class="text-sm uppercase tracking-widest text-muted">Documentation</p>
          <h1 class="mt-2 text-3xl sm:text-4xl font-semibold tracking-tight">Getting started</h1>
          <p class="mt-3 text-muted max-w-2xl leading-relaxed">
            Install the <code class="code-inline">relay</code> CLI, authenticate with your token, and
            expose a local port to the internet. Most flows take under a minute.
          </p>
        </div>

        <h2 id="install">Install</h2>
        <p>Choose the path that matches your setup. Homebrew is the quickest on macOS.</p>

        <div class="install-tabs my-6" data-install-tabs>
          <div role="tablist" class="flex flex-wrap gap-1.5 border-b border-subtle pb-3">
            {installMethods.map((m, i) => (
              <button
                type="button"
                role="tab"
                id={`tab-${m.id}`}
                aria-controls={`install-${m.id}`}
                aria-selected={i === 0 ? "true" : "false"}
                data-tab-target={m.id}
                class="install-tab inline-flex items-center gap-2 rounded-md border border-subtle px-3 py-1.5 text-sm transition"
              >
                <Icon name={m.icon} class="h-4 w-4" />
                {m.label}
              </button>
            ))}
          </div>

          <div
            id="install-homebrew"
            role="tabpanel"
            aria-labelledby="tab-homebrew"
            data-tab-panel="homebrew"
            class="install-panel pt-5 scroll-mt-24"
          >
            <p class="!mt-0">One-liner — taps the repo and installs the formula:</p>
            <CodeBlock
              lang="sh"
              code={`brew tap afomera/relay https://github.com/afomera/relay.git && brew install relay`}
            />
            <p>Verify the install:</p>
            <CodeBlock lang="sh" code={`relay --version`} />
          </div>

          <div
            id="install-cargo"
            role="tabpanel"
            aria-labelledby="tab-cargo"
            data-tab-panel="cargo"
            class="install-panel pt-5 scroll-mt-24"
            hidden
          >
            <p class="!mt-0">
              If you have a Rust toolchain, install directly from the repo. Works on Intel
              macOS, Linux, and Windows:
            </p>
            <CodeBlock
              lang="sh"
              code={`cargo install --git https://github.com/afomera/relay relay-cli`}
            />
            <p>
              Make sure <code class="code-inline">~/.cargo/bin</code> is on your <code class="code-inline">PATH</code>.
            </p>
          </div>

          <div
            id="install-script"
            role="tabpanel"
            aria-labelledby="tab-script"
            data-tab-panel="script"
            class="install-panel pt-5 scroll-mt-24"
            hidden
          >
            <p class="!mt-0">Prefer a one-liner? The install script grabs the right binary for your OS:</p>
            <CodeBlock
              lang="sh"
              code={`curl -fsSL https://raw.githubusercontent.com/afomera/relay/main/scripts/install.sh | sh`}
            />
          </div>
        </div>

        <h2 id="authenticate">Authenticate</h2>
        <p>
          Run <code class="code-inline">relay auth login</code> and relay opens your browser to
          the dashboard, where you sign in and authorize the CLI. Once you approve, relay saves the
          token locally so <code class="code-inline">relay http</code> and friends just work.
        </p>
        <CodeBlock lang="sh" code={`relay auth login`} />
        <p>
          The token is written to <code class="code-inline">config.toml</code> in relay's config
          directory — <code class="code-inline">~/Library/Application Support/dev.withrelay.relay/</code>
          on macOS, <code class="code-inline">~/.config/relay/</code> on Linux, and the equivalent
          <code class="code-inline">%APPDATA%</code> path on Windows. You only need to do this once
          per machine.
        </p>
        <div class="callout my-6">
          <Icon name="lucide:info" class="callout__icon" />
          <p class="callout__body">
            On a headless box? Pass <code class="code-inline">--no-browser</code> to print the
            sign-in URL, or skip the handshake with
            <code class="code-inline">relay auth login --token rly_pat_…</code> or the
            <code class="code-inline">RELAY_AUTH_TOKEN</code> environment variable.
          </p>
        </div>

        <h2 id="start-tunnel">Start a tunnel</h2>
        <p>Once authenticated, point relay at any local port. Four common shapes:</p>

        <h3 id="http">HTTP on a generated hostname</h3>
        <p>The fastest path. Relay picks a memorable subdomain on the shared zone:</p>
        <CodeBlock
          lang="sh"
          code={`relay http 3000
# → https://bright-otter.temporary.sharedwithrelay.com`}
        />

        <h3 id="reserved">Reserved wildcard hostname</h3>
        <p>Claim a stable name under your account's wildcard. Great for demos and webhooks:</p>
        <CodeBlock
          lang="sh"
          code={`relay http 3000 --hostname api.andrea
# → https://api.andrea.sharedwithrelay.com`}
        />

        <h3 id="custom-domain">Custom domain</h3>
        <p>
          Bring your own domain. Point a CNAME at relay, and certificates are provisioned
          automatically:
        </p>
        <CodeBlock lang="sh" code={`relay http 3000 --domain tunnel.mycompany.com`} />

        <h3 id="tcp">Raw TCP</h3>
        <p>For Postgres, Redis, SSH, or anything else that speaks TCP:</p>
        <CodeBlock
          lang="sh"
          code={`relay tcp 5432
# → tcp.sharedwithrelay.com:29734`}
        />

        <h2 id="next">What's next</h2>
        <ul role="list">
          <li>
            Explore the full CLI with <code class="code-inline">relay --help</code>.
          </li>
          <li>
            Want to run your own control plane? See the
            <a href="https://github.com/afomera/relay/blob/main/docs/self-hosting.md" target="_blank" rel="noopener">self-hosting guide</a>.
          </li>
          <li>
            Read the
            <a href="https://github.com/afomera/relay/blob/main/SPEC.md" target="_blank" rel="noopener">spec</a>
            for architecture and milestones.
          </li>
        </ul>

        <div class="mt-12 flex flex-wrap items-center gap-3">
          <a href="https://github.com/afomera/relay" target="_blank" rel="noopener" class="btn btn-ghost">
            <Icon name="lucide:github" class="h-4 w-4" />
            View source
          </a>
          <a href="/" class="btn btn-ghost">
            <Icon name="lucide:arrow-left" class="h-4 w-4" />
            Back home
          </a>
        </div>
      </article>

      <aside class="hidden lg:block">
        <div class="sticky top-24" data-toc-active>
          <p class="mb-3 text-xs uppercase tracking-widest text-muted">On this page</p>
          <nav class="flex flex-col gap-1.5 text-sm">
            {toc.map((item) => (
              <a
                href={`#${item.id}`}
                class:list={[
                  "toc-link border-l-2 border-transparent py-1 pl-3 text-muted transition hover:text-[color:var(--color-accent-600)] dark:hover:text-[color:var(--color-accent-400)]",
                  item.depth === 1 ? "pl-6" : "",
                ]}
              >
                {item.label}
              </a>
            ))}
          </nav>
        </div>
      </aside>
    </div>
  </section>

  <script is:inline>
    // Install tabs
    document.querySelectorAll("[data-install-tabs]").forEach((root) => {
      const tabs = root.querySelectorAll('[role="tab"]');
      const panels = root.querySelectorAll('[role="tabpanel"]');
      const activate = (id) => {
        tabs.forEach((t) => t.setAttribute("aria-selected", String(t.dataset.tabTarget === id)));
        panels.forEach((p) => p.toggleAttribute("hidden", p.dataset.tabPanel !== id));
      };
      tabs.forEach((tab) => {
        tab.addEventListener("click", () => activate(tab.dataset.tabTarget));
      });
      // Deep-link: #install-cargo etc. activates the matching tab.
      const syncFromHash = () => {
        const m = location.hash.match(/^#install-(homebrew|cargo|script)$/);
        if (m) activate(m[1]);
      };
      window.addEventListener("hashchange", syncFromHash);
      syncFromHash();
    });

    // Active-section highlighting for TOC
    const initToc = () => {
      const tocs = document.querySelectorAll("[data-toc-active]");
      if (!tocs.length) return;
      const headings = Array.from(document.querySelectorAll("article h2[id], article h3[id]"));
      if (!headings.length) return;

      const setActive = (id) => {
        tocs.forEach((root) => {
          root.querySelectorAll(".toc-link").forEach((a) => {
            const match = a.getAttribute("href") === "#" + id;
            a.toggleAttribute("aria-current", match);
            a.classList.toggle("toc-link--active", match);
          });
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (visible[0]) setActive(visible[0].target.id);
        },
        { rootMargin: "-15% 0px -70% 0px", threshold: 0 }
      );
      headings.forEach((h) => observer.observe(h));
    };

    initToc();
  </script>
</Layout>
