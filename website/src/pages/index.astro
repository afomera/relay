---
import Layout from "../layouts/Layout.astro";
import CodeBlock from "../components/CodeBlock.astro";
import { Icon } from "astro-icon/components";

const features = [
  {
    icon: "lucide:shield-check",
    title: "Self-hostable",
    body: "One binary, SQLite or Postgres, pluggable DNS provider for wildcard TLS. Own your tunnels.",
  },
  {
    icon: "lucide:zap",
    title: "QUIC under the hood",
    body: "Tunnels ride over QUIC for low latency and resilient connections across flaky networks.",
  },
  {
    icon: "lucide:globe",
    title: "Hostnames that stick",
    body: "Generated subdomains, reserved hostnames, wildcards, and your own custom domains.",
  },
  {
    icon: "lucide:plug-zap",
    title: "HTTP & raw TCP",
    body: "Expose web services or raw TCP like Postgres, Redis, and SSH with a single command.",
  },
  {
    icon: "lucide:box",
    title: "Install via Homebrew or Cargo",
    body: "Ship fast with `brew install` on macOS, or `cargo install` anywhere Rust runs.",
  },
  {
    icon: "lucide:scroll-text",
    title: "MIT licensed",
    body: "Free and open source. Built in Rust. Use it, fork it, ship it.",
  },
];

const installSnippet = `brew tap afomera/relay https://github.com/afomera/relay.git && brew install relay

relay auth login   # opens your browser to sign in & authorize the CLI
relay http 3000
# → https://bright-otter.temporary.sharedwithrelay.com`;
---

<Layout>
  <section class="container-page pt-20 pb-16 sm:pt-28 sm:pb-24">
    <div class="flex flex-col items-start gap-6">
      <span
        class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs"
        style="border-color: var(--color-accent-500); color: var(--color-accent-600);"
      >
        <Icon name="lucide:sparkles" class="h-3.5 w-3.5" />
        pre-alpha · built in Rust
      </span>
      <h1 class="text-4xl leading-tight tracking-tight sm:text-6xl sm:leading-[1.05] font-semibold">
        Tunnels you can
        <span style="color: var(--color-accent-500);">self-host.</span>
      </h1>
      <p class="max-w-2xl text-base sm:text-lg text-muted leading-relaxed">
        Relay is a self-hostable tunneling service — a Rust-based alternative to ngrok.
        Expose a local port to the internet over QUIC, with wildcard TLS and your own
        hostnames.
      </p>
      <div class="mt-2 flex flex-wrap items-center gap-3">
        <a href="/docs" class="btn btn-primary">
          Get started
          <Icon name="lucide:arrow-right" class="h-4 w-4" />
        </a>
        <a href="https://github.com/afomera/relay" target="_blank" rel="noopener" class="btn btn-ghost">
          <Icon name="lucide:github" class="h-4 w-4" />
          View on GitHub
        </a>
      </div>
    </div>

    <div class="mt-12 max-w-3xl">
      <CodeBlock lang="sh" code={installSnippet} />
    </div>
  </section>

  <section class="border-t border-subtle">
    <div class="container-page py-16 sm:py-20">
      <div class="mb-10 flex items-end justify-between">
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">Why relay</h2>
        <a href="/docs" class="link-accent text-sm inline-flex items-center gap-1">
          Read the docs
          <Icon name="lucide:arrow-right" class="h-3.5 w-3.5" />
        </a>
      </div>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-6">
        <div
          class="rounded-xl border border-subtle p-6 sm:col-span-4 sm:p-8 transition hover:border-[color:var(--color-accent-500)]"
          style="background-color: var(--bg-elevated);"
        >
          <div
            class="mb-5 inline-flex size-10 items-center justify-center rounded-md"
            style="background-color: var(--color-accent-100); color: var(--color-accent-700);"
          >
            <Icon name="lucide:shield-check" class="size-5" />
          </div>
          <h3 class="mb-2 text-lg font-semibold tracking-tight">Fully self-hostable</h3>
          <p class="max-w-[48ch] text-sm text-muted leading-relaxed text-pretty">
            One binary. SQLite or Postgres. Pluggable DNS provider for wildcard TLS. Run the
            control plane on your own infrastructure and keep your tunnel traffic where you
            trust it.
          </p>
        </div>
        <div
          class="rounded-xl border border-subtle p-6 sm:col-span-2 sm:p-8 transition hover:border-[color:var(--color-accent-500)]"
          style="background-color: var(--bg-elevated);"
        >
          <div
            class="mb-5 inline-flex size-10 items-center justify-center rounded-md"
            style="background-color: var(--color-accent-100); color: var(--color-accent-700);"
          >
            <Icon name="lucide:zap" class="size-5" />
          </div>
          <h3 class="mb-2 text-lg font-semibold tracking-tight">QUIC under the hood</h3>
          <p class="text-sm text-muted leading-relaxed text-pretty">
            Low latency, stream multiplexing, and resilient reconnects across flaky networks.
          </p>
        </div>
        <div
          class="rounded-xl border border-subtle p-5 sm:col-span-2 transition hover:border-[color:var(--color-accent-500)]"
          style="background-color: var(--bg-elevated);"
        >
          <div
            class="mb-4 inline-flex size-9 items-center justify-center rounded-md"
            style="background-color: var(--color-accent-100); color: var(--color-accent-700);"
          >
            <Icon name="lucide:globe" class="size-4.5" />
          </div>
          <h3 class="mb-1.5 font-semibold tracking-tight">Hostnames that stick</h3>
          <p class="text-sm text-muted leading-relaxed">Generated, reserved, wildcard, or your own custom domain.</p>
        </div>
        <div
          class="rounded-xl border border-subtle p-5 sm:col-span-2 transition hover:border-[color:var(--color-accent-500)]"
          style="background-color: var(--bg-elevated);"
        >
          <div
            class="mb-4 inline-flex size-9 items-center justify-center rounded-md"
            style="background-color: var(--color-accent-100); color: var(--color-accent-700);"
          >
            <Icon name="lucide:plug-zap" class="size-4.5" />
          </div>
          <h3 class="mb-1.5 font-semibold tracking-tight">HTTP & raw TCP</h3>
          <p class="text-sm text-muted leading-relaxed">Web services or Postgres, Redis, SSH — one command.</p>
        </div>
        <div
          class="rounded-xl border border-subtle p-5 sm:col-span-2 transition hover:border-[color:var(--color-accent-500)]"
          style="background-color: var(--bg-elevated);"
        >
          <div
            class="mb-4 inline-flex size-9 items-center justify-center rounded-md"
            style="background-color: var(--color-accent-100); color: var(--color-accent-700);"
          >
            <Icon name="lucide:box" class="size-4.5" />
          </div>
          <h3 class="mb-1.5 font-semibold tracking-tight">Install in seconds</h3>
          <p class="text-sm text-muted leading-relaxed"><code class="code-inline">brew install</code> on macOS, <code class="code-inline">cargo install</code> anywhere Rust runs.</p>
        </div>
        <div
          class="rounded-xl border border-subtle p-5 sm:col-span-6 sm:p-6 transition hover:border-[color:var(--color-accent-500)]"
          style="background-color: var(--bg-elevated);"
        >
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-5">
            <div
              class="inline-flex size-9 items-center justify-center rounded-md"
              style="background-color: var(--color-accent-100); color: var(--color-accent-700);"
            >
              <Icon name="lucide:scroll-text" class="size-4.5" />
            </div>
            <div>
              <h3 class="font-semibold tracking-tight">MIT licensed, open forever</h3>
              <p class="mt-1 text-sm text-muted leading-relaxed">Free and open source. Built in Rust. Use it, fork it, ship it — no catches.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ============================== */}
  {/* ONE COMMAND split (unchanged)  */}
  {/* ============================== */}
  <section class="border-t border-subtle">
    <div class="container-page py-16 sm:py-20">
      <div class="grid gap-10 lg:grid-cols-2 lg:gap-16">
        <div>
          <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">
            One command, you're online.
          </h2>
          <p class="mt-4 text-muted leading-relaxed">
            Authenticate once, then point relay at any local port. Pick a generated
            hostname, reserve one on the shared domain, or bring your own.
          </p>
          <ul class="mt-6 space-y-3 text-sm text-muted" role="list">
            <li class="flex gap-3">
              <Icon name="lucide:check" class="mt-1 h-4 w-4 shrink-0" style="color: var(--color-accent-500);" />
              <span>Generated subdomains on the shared zone for ephemeral sharing.</span>
            </li>
            <li class="flex gap-3">
              <Icon name="lucide:check" class="mt-1 h-4 w-4 shrink-0" style="color: var(--color-accent-500);" />
              <span>Reserved wildcard hostnames like <code class="code-inline">api.andrea</code>.</span>
            </li>
            <li class="flex gap-3">
              <Icon name="lucide:check" class="mt-1 h-4 w-4 shrink-0" style="color: var(--color-accent-500);" />
              <span>Custom domains with automatic wildcard TLS.</span>
            </li>
            <li class="flex gap-3">
              <Icon name="lucide:check" class="mt-1 h-4 w-4 shrink-0" style="color: var(--color-accent-500);" />
              <span>Raw TCP on a shared ingress address.</span>
            </li>
          </ul>
        </div>
        <div class="space-y-3">
          <CodeBlock lang="http" code={`relay http 3000
# → https://bright-otter.temporary.sharedwithrelay.com`} />
          <CodeBlock lang="wildcard" code={`relay http 3000 --hostname api.andrea
# → https://api.andrea.sharedwithrelay.com`} />
          <CodeBlock lang="domain" code={`relay http 3000 --domain tunnel.mycompany.com`} />
          <CodeBlock lang="tcp" code={`relay tcp 5432
# → tcp.sharedwithrelay.com:29734`} />
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-subtle bg-[color:var(--color-accent-50)] dark:bg-[color:var(--bg-elevated)]">
    <div class="container-page py-16 sm:py-20">
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <div class="flex flex-col items-start gap-4">
          <h2 class="max-w-[22ch] text-2xl sm:text-3xl font-semibold tracking-tight text-balance text-[#1c1917] dark:text-[color:var(--fg)]">
            Ready to start tunneling?
          </h2>
          <p class="max-w-[56ch] text-pretty text-[#57534e] dark:text-muted">
            Install the CLI, sign in from your browser, and expose a port. Zero to URL in
            under a minute.
          </p>
          <div class="mt-2 flex flex-wrap items-center gap-3">
            <a href="/docs" class="btn btn-primary">
              Read the docs
              <Icon name="lucide:arrow-right" class="h-4 w-4" />
            </a>
            <a href="https://github.com/afomera/relay" target="_blank" rel="noopener" class="btn btn-ghost">
              <Icon name="lucide:github" class="h-4 w-4" />
              GitHub
            </a>
          </div>
        </div>
        <div class="space-y-3">
          <CodeBlock lang="sh" code={`brew tap afomera/relay https://github.com/afomera/relay.git && brew install relay`} />
          <CodeBlock lang="sh" code={`relay auth login`} />
          <CodeBlock lang="sh" code={`relay http 3000`} />
        </div>
      </div>
    </div>
  </section>
</Layout>
