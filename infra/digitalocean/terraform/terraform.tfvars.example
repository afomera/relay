# Copy to terraform.tfvars (which is .gitignored) and fill in.

# ---- provider tokens ----
do_token             = "dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
cloudflare_api_token = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---- droplet ----
# doctl compute ssh-key list
ssh_key_ids   = [12345678]
region        = "nyc3"
droplet_size  = "s-1vcpu-2gb"
# Tighten to your office IP or VPN in prod.
# ssh_allow_from = ["203.0.113.7/32"]

# ---- domains ----
tunnel_base_domain = "sharedwithrelay.com"
tunnel_zone_id     = "cloudflare-zone-id-for-sharedwithrelay-com"
admin_hostname     = "dash.withrelay.dev"
admin_zone_id      = "cloudflare-zone-id-for-withrelay-dev"
# Optional: shown when visitors hit the apex of tunnel_base_domain with no
# subdomain. Omit (or set to "") to fall back to the generic 404.
marketing_url      = "withrelay.dev"

# ---- relay config ----
github_oauth_client_id     = "Iv1.abcdef..."
github_oauth_client_secret = "secret-from-github-oauth-app"
acme_contact_email         = "you@example.com"

# ---- database ----
#
# Leave `database_url` empty (default) to use on-disk SQLite at
# /var/lib/relay/relay.db — the simplest single-host deploy.
#
# Set it to a managed-Postgres connection string to point relay at Postgres
# instead. The URL is injected as DATABASE_URL on the droplet and relayd
# picks it up via `db.url_env = "DATABASE_URL"`. Any libpq-style params go
# through untouched — keep `sslmode=require` (or verify-full) for managed
# services that require TLS.
#
# PlanetScale Postgres (prod runs on 18.3):
# database_url = "postgres://USER:PASS@HOST.pgsql.planetscale.com:5432/DB?sslmode=require"
#
# Neon / Supabase / Crunchy Bridge connection strings follow the same shape.
#
# Optional pool tuning. Leave unset for relay-db defaults (SQLite=10,
# Postgres=20, 5s acquire timeout).
# db_max_connections      = 20
# db_acquire_timeout_secs = 5

# Leave empty to allow any GitHub user; list one or more GitHub orgs to
# restrict sign-in to their members. Case-insensitive. For a company
# deploy, set to ["mycompany"].
# github_allowed_orgs = []

# Start on staging; flip to the prod URL once a staging cert issues cleanly.
# acme_directory = "https://acme-v02.api.letsencrypt.org/directory"

# Subdomain Relay uses for ACME DNS-01 delegation when issuing certs for
# customers' wildcard custom domains. Customers CNAME
# `_acme-challenge.<their-domain>` here once and renewals run unattended.
# Must live under the same Cloudflare zone as tunnel_zone_id (the DNS
# provider is single-zone today). Leave empty to disable wildcard custom
# domains.
# acme_delegation_zone = "acme-delegate.sharedwithrelay.com"

# Leave blank to let Terraform generate a random 32-byte key. Set a fixed
# value only when migrating a cert store between droplets.
# relay_data_key = ""

# Point at your fork if you've customised anything.
# relay_git_url = "https://github.com/afomera/relay.git"
# relay_git_ref = "main"
